<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CadForge Viewer</title>
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
body { background: #1a1a2e; color: #e0e0e0; font-family: -apple-system, system-ui, sans-serif; overflow: hidden; }
#canvas { width: 100vw; height: 100vh; display: block; }

#toolbar {
    position: fixed; top: 12px; left: 12px;
    display: flex; gap: 6px; z-index: 10;
}
#toolbar button {
    background: rgba(30,30,50,0.85); border: 1px solid #444; color: #ccc;
    padding: 6px 12px; border-radius: 4px; cursor: pointer; font-size: 12px;
    backdrop-filter: blur(8px);
}
#toolbar button:hover { background: rgba(60,60,100,0.9); color: #fff; }
#toolbar button.active { border-color: #6c8cff; color: #8cacff; }

#status {
    position: fixed; bottom: 12px; left: 12px;
    background: rgba(30,30,50,0.85); padding: 8px 14px; border-radius: 6px;
    font-size: 12px; backdrop-filter: blur(8px); z-index: 10;
    border: 1px solid #333;
}
#status .dot { display: inline-block; width: 8px; height: 8px; border-radius: 50%; margin-right: 6px; }
#status .dot.ok { background: #4caf50; }
#status .dot.building { background: #ff9800; animation: pulse 0.8s infinite; }
#status .dot.error { background: #f44336; }
@keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.3; } }

#info {
    position: fixed; top: 12px; right: 12px;
    background: rgba(30,30,50,0.85); padding: 10px 14px; border-radius: 6px;
    font-size: 11px; backdrop-filter: blur(8px); z-index: 10;
    border: 1px solid #333; min-width: 180px;
}
#info h3 { font-size: 13px; margin-bottom: 6px; color: #8cacff; }
#info .row { display: flex; justify-content: space-between; margin: 2px 0; }
#info .label { color: #888; }

#layers {
    position: fixed; bottom: 12px; right: 12px;
    background: rgba(30,30,50,0.85); padding: 10px 14px; border-radius: 6px;
    font-size: 11px; backdrop-filter: blur(8px); z-index: 10;
    border: 1px solid #333; max-height: 300px; overflow-y: auto;
}
#layers h3 { font-size: 13px; margin-bottom: 6px; color: #8cacff; }
#layers label { display: block; padding: 2px 0; cursor: pointer; }
#layers label:hover { color: #fff; }
#layers input { margin-right: 6px; }

#toast {
    position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%);
    background: rgba(30,30,50,0.95); padding: 20px 30px; border-radius: 8px;
    font-size: 14px; z-index: 100; border: 1px solid #6c8cff;
    display: none; text-align: center;
}
</style>
</head>
<body>

<canvas id="canvas"></canvas>

<div id="toolbar">
    <button onclick="resetView()">Reset</button>
    <button onclick="setView('top')">Top</button>
    <button onclick="setView('front')">Front</button>
    <button onclick="setView('right')">Right</button>
    <button onclick="setView('iso')">Iso</button>
    <button onclick="toggleWireframe()" id="btnWire">Wire</button>
    <button onclick="toggleGrid()" id="btnGrid">Grid</button>
    <button onclick="reloadModel()" id="btnReload" style="border-color:#4caf50;color:#4caf50">Reload</button>
    <button onclick="toggleFly()" id="btnFly">Fly</button>
    <button onclick="toggleSun()" id="btnSun" style="border-color:#ff9800;color:#ff9800">Sun</button>
</div>

<div id="log" style="position:fixed;bottom:50px;left:12px;background:rgba(30,30,50,0.9);padding:8px 12px;border-radius:6px;font-size:11px;max-width:500px;max-height:150px;overflow-y:auto;z-index:10;border:1px solid #333;font-family:monospace;display:none"></div>

<div id="status">
    <span class="dot ok" id="statusDot"></span>
    <span id="statusText">Ready</span>
</div>

<div id="info">
    <h3>CadForge</h3>
    <div class="row"><span class="label">Objects:</span><span id="objCount">-</span></div>
    <div class="row"><span class="label">Build:</span><span id="buildTime">-</span></div>
    <div class="row"><span class="label">Selected:</span><span id="selName">-</span></div>
</div>

<div id="layers">
    <h3>Layers</h3>
    <div id="layerList"></div>
</div>

<div id="toast"></div>

<!-- Three.js from CDN -->
<script type="importmap">
{
    "imports": {
        "three": "https://cdn.jsdelivr.net/npm/three@0.170.0/build/three.module.js",
        "three/addons/": "https://cdn.jsdelivr.net/npm/three@0.170.0/examples/jsm/"
    }
}
</script>

<script type="module">
import * as THREE from 'three';
import { OrbitControls } from 'three/addons/controls/OrbitControls.js';
import { GLTFLoader } from 'three/addons/loaders/GLTFLoader.js';

// Scene setup
const canvas = document.getElementById('canvas');
const renderer = new THREE.WebGLRenderer({ canvas, antialias: true });
renderer.setSize(window.innerWidth, window.innerHeight);
renderer.setPixelRatio(window.devicePixelRatio);
renderer.setClearColor(0x1a1a2e);
renderer.shadowMap.enabled = true;
renderer.shadowMap.type = THREE.PCFSoftShadowMap;

const scene = new THREE.Scene();
// FreeCAD uses Z-up, three.js uses Y-up — set scene up to Z
scene.up.set(0, 0, 1);

// Camera
const camera = new THREE.PerspectiveCamera(45, window.innerWidth / window.innerHeight, 10, 200000);
camera.up.set(0, 0, 1);
camera.position.set(30000, -40000, 25000);

// Controls
const controls = new OrbitControls(camera, canvas);
controls.enableDamping = true;
controls.dampingFactor = 0.1;
controls.target.set(11000, 25000, 2000);
controls.update();

// Lights
const ambientLight = new THREE.AmbientLight(0xffffff, 0.5);
scene.add(ambientLight);

const dirLight = new THREE.DirectionalLight(0xffffff, 1.0);
dirLight.position.set(20000, -15000, 30000);
dirLight.castShadow = true;
dirLight.shadow.mapSize.width = 4096;
dirLight.shadow.mapSize.height = 4096;
dirLight.shadow.camera.near = 100;
dirLight.shadow.camera.far = 300000;
dirLight.shadow.camera.left = -40000;
dirLight.shadow.camera.right = 40000;
dirLight.shadow.camera.top = 40000;
dirLight.shadow.camera.bottom = -40000;
dirLight.shadow.bias = -0.0005;
const dirTarget = new THREE.Object3D();
dirTarget.position.set(11000, 25000, 1500);
scene.add(dirTarget);
dirLight.target = dirTarget;
scene.add(dirLight);

const fillLight = new THREE.DirectionalLight(0x8888ff, 0.3);
fillLight.position.set(-15000, 20000, 10000);
scene.add(fillLight);

// Ground plane для приёма теней (PlaneGeometry = XY, normal +Z — уже правильно для Z-up)
const groundGeo = new THREE.PlaneGeometry(120000, 120000);
const groundMat = new THREE.ShadowMaterial({ opacity: 0.35 });
const groundPlane = new THREE.Mesh(groundGeo, groundMat);
groundPlane.position.set(11000, 25000, -5);
groundPlane.receiveShadow = true;
scene.add(groundPlane);

// Grid — лежит на XY плоскости (Z-up мир)
const gridHelper = new THREE.GridHelper(60000, 60, 0x444466, 0x333355);
gridHelper.rotation.x = Math.PI / 2;
scene.add(gridHelper);

// Axes
const axesHelper = new THREE.AxesHelper(5000);
scene.add(axesHelper);

// ============================================================
// FLY MODE — WASD + стрелки + мышь
// ============================================================
let flyMode = false;
let flySpeed = 100; // базовая скорость (мм за тик), Shift ускоряет x5
const flyKeys = {};
let flyYaw = 0;
let flyPitch = -0.3; // slightly looking down
let pointerLocked = false;

window.toggleFly = function() {
    flyMode = !flyMode;
    document.getElementById('btnFly').classList.toggle('active', flyMode);

    if (flyMode) {
        controls.enabled = false;
        // Init fly direction from current camera
        const dir = new THREE.Vector3();
        camera.getWorldDirection(dir);
        flyYaw = Math.atan2(dir.y, dir.x);
        flyPitch = Math.asin(THREE.MathUtils.clamp(dir.z, -1, 1));
        canvas.requestPointerLock();
        log('Fly mode ON — WASD/arrows move, mouse look, Q/E up/down, Esc exit');
    } else {
        controls.enabled = true;
        document.exitPointerLock();
        log('Fly mode OFF — orbit controls');
    }
};

document.addEventListener('pointerlockchange', () => {
    pointerLocked = document.pointerLockElement === canvas;
    if (!pointerLocked && flyMode) {
        // User pressed Esc — exit fly mode
        flyMode = false;
        controls.enabled = true;
        document.getElementById('btnFly').classList.remove('active');
    }
});

canvas.addEventListener('mousemove', (e) => {
    if (!flyMode || !pointerLocked) return;
    const sensitivity = 0.0008;
    flyYaw -= e.movementX * sensitivity;
    flyPitch -= e.movementY * sensitivity;
    flyPitch = THREE.MathUtils.clamp(flyPitch, -Math.PI / 2 + 0.05, Math.PI / 2 - 0.05);
});

document.addEventListener('keydown', (e) => {
    flyKeys[e.code] = true;
    if (flyMode) {
        // +/= ускорить, -/_ замедлить
        if (e.code === 'Equal' || e.code === 'NumpadAdd') {
            flySpeed = Math.min(flySpeed * 1.5, 5000);
            log(`Fly speed: ${flySpeed.toFixed(0)}`);
        }
        if (e.code === 'Minus' || e.code === 'NumpadSubtract') {
            flySpeed = Math.max(flySpeed / 1.5, 10);
            log(`Fly speed: ${flySpeed.toFixed(0)}`);
        }
    }
});

document.addEventListener('keyup', (e) => {
    flyKeys[e.code] = false;
});

// Колёсико / тачпад скролл в fly mode — меняет скорость
canvas.addEventListener('wheel', (e) => {
    if (!flyMode) return;
    e.preventDefault();
    flySpeed *= e.deltaY > 0 ? 0.8 : 1.25;
    flySpeed = THREE.MathUtils.clamp(flySpeed, 10, 5000);
    log(`Fly speed: ${flySpeed.toFixed(0)}`);
}, { passive: false });

function updateFly(delta) {
    if (!flyMode) return;

    // Shift = ускорение x5, колёсико мыши меняет flySpeed
    const boost = flyKeys['ShiftLeft'] || flyKeys['ShiftRight'] ? 5 : 1;
    const speed = flySpeed * boost * delta;

    // Вектор направления камеры (куда смотрим)
    const lookDir = new THREE.Vector3(
        Math.cos(flyPitch) * Math.cos(flyYaw),
        Math.cos(flyPitch) * Math.sin(flyYaw),
        Math.sin(flyPitch),
    );
    // Вектор вправо (перпендикулярно направлению, в горизонтальной плоскости)
    const worldUp = new THREE.Vector3(0, 0, 1);
    const right = new THREE.Vector3().crossVectors(lookDir, worldUp).normalize();
    // Вектор вверх камеры (перпендикулярно forward и right)
    const camUp = new THREE.Vector3().crossVectors(right, lookDir).normalize();

    const move = new THREE.Vector3();
    // W/S — движение вдоль вектора камеры (вперёд/назад включая наклон)
    if (flyKeys['KeyW'] || flyKeys['ArrowUp'])    move.add(lookDir);
    if (flyKeys['KeyS'] || flyKeys['ArrowDown'])  move.sub(lookDir);
    // A/D — стрейф влево/вправо
    if (flyKeys['KeyA'] || flyKeys['ArrowLeft'])   move.sub(right);
    if (flyKeys['KeyD'] || flyKeys['ArrowRight']) move.add(right);
    // Q/Space — вверх, E — вниз (по мировой оси Z)
    if (flyKeys['KeyQ'] || flyKeys['Space'])      move.add(worldUp);
    if (flyKeys['KeyE'])                          move.sub(worldUp);

    if (move.lengthSq() > 0) {
        move.normalize().multiplyScalar(speed);
        camera.position.add(move);
    }

    // Обновить направление камеры
    const target = camera.position.clone().add(lookDir);
    camera.lookAt(target);

    // Синхронизировать orbit target для переключения обратно
    controls.target.copy(target);
}

// ============================================================
// SUN SIMULATION — NOAA Solar Position Algorithm
// ============================================================
let sunLat = 41.4;   // default latitude (Barcelona area)
let sunLon = 2.17;   // default longitude
let sunNorthDeg = 0;  // plot orientation: degrees from Y+ axis clockwise to true North
let sunTzOffset = null; // null = auto from longitude, or manual override (hours from UTC, e.g. -3)
let sunTimeMinutes = 720; // minutes from midnight (12:00)
let sunDateStr = new Date().toISOString().slice(0, 10);
let sunAnimating = false;
let sunAnimSpeed = 60; // x realtime

function solarPosition(lat, lon, localTimeMinutes, dateStr) {
    // NOAA Solar Position — accepts local clock time + date string
    // Returns { azimuth (0=N, 90=E, 180=S, 270=W), elevation (degrees) }
    const rad = Math.PI / 180;
    const parts = dateStr.split('-');
    const year = +parts[0], month = +parts[1], day = +parts[2];
    const localHours = localTimeMinutes / 60;

    // Timezone offset: manual override or estimate from longitude
    const tzOffset = sunTzOffset !== null ? sunTzOffset : Math.round(lon / 15);
    const utcHours = localHours - tzOffset;

    // Julian Day Number
    const a = Math.floor((14 - month) / 12);
    const y2 = year + 4800 - a;
    const m2 = month + 12 * a - 3;
    const JDN = day + Math.floor((153 * m2 + 2) / 5) + 365 * y2
              + Math.floor(y2 / 4) - Math.floor(y2 / 100) + Math.floor(y2 / 400) - 32045;
    const JD = JDN + (utcHours - 12) / 24;
    const T = (JD - 2451545.0) / 36525.0;

    // Geometric mean longitude & anomaly
    let L0 = (280.46646 + T * (36000.76983 + T * 0.0003032)) % 360;
    if (L0 < 0) L0 += 360;
    let M0 = (357.52911 + T * (35999.05029 - T * 0.0001537)) % 360;
    if (M0 < 0) M0 += 360;
    const ecc = 0.016708634 - T * (0.000042037 + T * 0.0000001267);

    // Equation of center
    const C = (1.914602 - T * (0.004817 + T * 0.000014)) * Math.sin(M0 * rad)
            + (0.019993 - T * 0.000101) * Math.sin(2 * M0 * rad)
            + 0.000289 * Math.sin(3 * M0 * rad);
    const sunLon_ = L0 + C;

    // Obliquity
    const omega = 125.04 - 1934.136 * T;
    const eps0 = 23 + (26 + (21.448 - T * (46.815 + T * (0.00059 - T * 0.001813))) / 60) / 60;
    const eps = eps0 + 0.00256 * Math.cos(omega * rad);

    // Apparent longitude & declination
    const lambda = sunLon_ - 0.00569 - 0.00478 * Math.sin(omega * rad);
    const dec = Math.asin(Math.sin(eps * rad) * Math.sin(lambda * rad));

    // Equation of time (minutes)
    const tanHalfEps = Math.tan(eps * rad / 2);
    const yy = tanHalfEps * tanHalfEps;
    const eqTime = 4 / rad * (
        yy * Math.sin(2 * L0 * rad)
        - 2 * ecc * Math.sin(M0 * rad)
        + 4 * ecc * yy * Math.sin(M0 * rad) * Math.cos(2 * L0 * rad)
        - 0.5 * yy * yy * Math.sin(4 * L0 * rad)
        - 1.25 * ecc * ecc * Math.sin(2 * M0 * rad)
    );

    // True solar time & hour angle
    const solarTime = localTimeMinutes + eqTime + 4 * lon - 60 * tzOffset;
    let ha = solarTime / 4 - 180;
    if (ha < -180) ha += 360;
    if (ha > 180) ha -= 360;

    const latR = lat * rad;
    const haR = ha * rad;

    // Elevation
    const sinElev = Math.sin(latR) * Math.sin(dec) + Math.cos(latR) * Math.cos(dec) * Math.cos(haR);
    const elevation = Math.asin(THREE.MathUtils.clamp(sinElev, -1, 1)) / rad;

    // Azimuth (from North, clockwise)
    const cosAz = (Math.sin(dec) - Math.sin(latR) * sinElev) / (Math.cos(latR) * Math.cos(Math.asin(sinElev)));
    let azimuth;
    if (ha > 0) {
        azimuth = (360 - Math.acos(THREE.MathUtils.clamp(cosAz, -1, 1)) / rad) % 360;
    } else {
        azimuth = Math.acos(THREE.MathUtils.clamp(cosAz, -1, 1)) / rad;
    }

    return { azimuth, elevation };
}

// Sun marker (sphere + line to ground + compass)
const sunMarkerGroup = new THREE.Group();
const sunSphere = new THREE.Mesh(
    new THREE.SphereGeometry(1500, 16, 16),
    new THREE.MeshBasicMaterial({ color: 0xffcc00 })
);
sunMarkerGroup.add(sunSphere);

// Line from sun to ground (dashed)
const sunLineMat = new THREE.LineDashedMaterial({ color: 0xffcc00, dashSize: 500, gapSize: 300, opacity: 0.5, transparent: true });
const sunLineGeo = new THREE.BufferGeometry().setFromPoints([new THREE.Vector3(0,0,0), new THREE.Vector3(0,0,-1)]);
const sunLine = new THREE.Line(sunLineGeo, sunLineMat);
sunLine.computeLineDistances();
sunMarkerGroup.add(sunLine);

// Ground dot under sun
const sunDot = new THREE.Mesh(
    new THREE.CircleGeometry(800, 16),
    new THREE.MeshBasicMaterial({ color: 0xffaa00, opacity: 0.4, transparent: true })
);
sunMarkerGroup.add(sunDot);

// Sun glow (sprite)
const sunGlowCanvas = document.createElement('canvas');
sunGlowCanvas.width = 64; sunGlowCanvas.height = 64;
const gctx = sunGlowCanvas.getContext('2d');
const grad = gctx.createRadialGradient(32, 32, 0, 32, 32, 32);
grad.addColorStop(0, 'rgba(255,220,80,0.8)');
grad.addColorStop(0.3, 'rgba(255,180,40,0.3)');
grad.addColorStop(1, 'rgba(255,150,0,0)');
gctx.fillStyle = grad;
gctx.fillRect(0, 0, 64, 64);
const sunGlow = new THREE.Sprite(new THREE.SpriteMaterial({
    map: new THREE.CanvasTexture(sunGlowCanvas),
    blending: THREE.AdditiveBlending, depthWrite: false
}));
sunGlow.scale.set(8000, 8000, 1);
sunMarkerGroup.add(sunGlow);

scene.add(sunMarkerGroup);

// Compass rose (N/S/E/W labels around the model)
const compassGroup = new THREE.Group();
const compassLabels = [
    { text: 'N', angle: 0 },
    { text: 'E', angle: 90 },
    { text: 'S', angle: 180 },
    { text: 'W', angle: 270 },
];

function makeTextSprite(text, color) {
    const c = document.createElement('canvas');
    c.width = 64; c.height = 64;
    const ctx = c.getContext('2d');
    ctx.font = 'bold 48px sans-serif';
    ctx.fillStyle = color;
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillText(text, 32, 32);
    const sprite = new THREE.Sprite(new THREE.SpriteMaterial({
        map: new THREE.CanvasTexture(c), depthTest: false
    }));
    sprite.scale.set(2000, 2000, 1);
    return sprite;
}

for (const { text, angle } of compassLabels) {
    const sprite = makeTextSprite(text, text === 'N' ? '#ff4444' : '#888888');
    sprite.userData.compassAngle = angle;
    compassGroup.add(sprite);
}
scene.add(compassGroup);

function updateCompass(centerX, centerY, radius) {
    const rad = Math.PI / 180;
    const northRad = sunNorthDeg * rad;
    compassGroup.children.forEach(sprite => {
        const angle = sprite.userData.compassAngle;
        const a = (angle - sunNorthDeg) * rad;
        // azimuth convention: 0=+Y, 90=+X
        sprite.position.set(
            centerX + Math.sin(a) * radius,
            centerY + Math.cos(a) * radius,
            200
        );
    });
}

function updateSunLight(azDeg, elDeg) {
    const rad = Math.PI / 180;
    // Adjust azimuth by plot north orientation
    const az = (azDeg - sunNorthDeg) * rad;
    const el = Math.max(elDeg, 0.5) * rad; // clamp slightly above horizon for shadow

    // Z-up: azimuth 0=North(+Y), 90=East(+X), 180=South(-Y)
    const dist = 80000;
    const x = Math.sin(az) * Math.cos(el) * dist;
    const y = Math.cos(az) * Math.cos(el) * dist;
    const z = Math.sin(el) * dist;

    const cx = dirTarget.position.x;
    const cy = dirTarget.position.y;

    dirLight.position.set(cx + x, cy + y, Math.max(z, 500));

    // Sun marker — show at shorter distance so it's visible
    const markerDist = 35000;
    const mx = Math.sin(az) * Math.cos(el) * markerDist;
    const my = Math.cos(az) * Math.cos(el) * markerDist;
    const mz = Math.sin(el) * markerDist;
    sunSphere.position.set(cx + mx, cy + my, mz);
    sunGlow.position.copy(sunSphere.position);

    // Dashed line from sun to ground
    const sunPos = sunSphere.position;
    const groundPos = new THREE.Vector3(sunPos.x, sunPos.y, 0);
    sunLineGeo.setFromPoints([sunPos, groundPos]);
    sunLineGeo.attributes.position.needsUpdate = true;
    sunLine.computeLineDistances();

    // Ground dot
    sunDot.position.set(sunPos.x, sunPos.y, 5);

    // Show/hide sun marker
    sunMarkerGroup.visible = elDeg > -2;
    if (elDeg <= 0) {
        sunSphere.material.color.setHex(0x994400);
        sunGlow.material.opacity = 0.2;
    } else if (elDeg < 10) {
        sunSphere.material.color.setHex(0xff8800);
        sunGlow.material.opacity = 0.6;
    } else {
        sunSphere.material.color.setHex(0xffcc00);
        sunGlow.material.opacity = 1.0;
    }

    // Dynamic shadow frustum — expand at low sun angles for long shadows
    const shadowSize = elDeg > 30 ? 40000 : elDeg > 10 ? 60000 : 90000;
    dirLight.shadow.camera.left = -shadowSize;
    dirLight.shadow.camera.right = shadowSize;
    dirLight.shadow.camera.top = shadowSize;
    dirLight.shadow.camera.bottom = -shadowSize;
    dirLight.shadow.camera.updateProjectionMatrix();

    // Update compass
    updateCompass(cx, cy, 38000);

    // Intensity & color based on elevation
    if (elDeg <= 0) {
        dirLight.intensity = 0;
        ambientLight.intensity = 0.15;
        fillLight.intensity = 0.05;
        renderer.setClearColor(0x0a0a1e);
    } else if (elDeg < 5) {
        dirLight.intensity = 0.3;
        dirLight.color.setHex(0xff8844);
        ambientLight.intensity = 0.2;
        fillLight.intensity = 0.1;
        renderer.setClearColor(0x1a1020);
    } else if (elDeg < 20) {
        const t = (elDeg - 5) / 15;
        dirLight.intensity = 0.3 + t * 0.7;
        dirLight.color.setHex(t < 0.5 ? 0xffaa66 : 0xffddaa);
        ambientLight.intensity = 0.2 + t * 0.3;
        fillLight.intensity = 0.1 + t * 0.2;
        const r = Math.round(0x1a + t * (0x87 - 0x1a));
        const g = Math.round(0x10 + t * (0xce - 0x10));
        const b = Math.round(0x20 + t * (0xfa - 0x20));
        renderer.setClearColor((r << 16) | (g << 8) | b);
    } else {
        dirLight.intensity = 1.0;
        dirLight.color.setHex(0xffffff);
        ambientLight.intensity = 0.5;
        fillLight.intensity = 0.3;
        renderer.setClearColor(0x87cefa);
    }
}

function applySunPosition() {
    const { azimuth, elevation } = solarPosition(sunLat, sunLon, sunTimeMinutes, sunDateStr);
    updateSunLight(azimuth, elevation);

    // Update UI displays
    const hh = String(Math.floor(sunTimeMinutes / 60)).padStart(2, '0');
    const mm = String(Math.round(sunTimeMinutes % 60)).padStart(2, '0');
    const timeLabel = document.getElementById('sunTimeLabel');
    if (timeLabel) timeLabel.textContent = `${hh}:${mm}`;
    const slider = document.getElementById('sunSlider');
    if (slider) slider.value = sunTimeMinutes;
    const elLabel = document.getElementById('sunElLabel');
    if (elLabel) elLabel.textContent = `Az ${azimuth.toFixed(0)}° El ${elevation.toFixed(1)}°`;
}

function updateSunAnim(deltaSec) {
    if (!sunAnimating) return;
    sunTimeMinutes += sunAnimSpeed * deltaSec / 60; // speed is x-realtime
    if (sunTimeMinutes >= 1440) sunTimeMinutes -= 1440;
    if (sunTimeMinutes < 0) sunTimeMinutes += 1440;
    applySunPosition();
}

function createSunPanel() {
    const panel = document.createElement('div');
    panel.id = 'sunPanel';
    panel.style.cssText = `
        position:fixed; bottom:12px; left:50%; transform:translateX(-50%);
        background:rgba(30,30,50,0.9); padding:10px 16px; border-radius:8px;
        font-size:11px; backdrop-filter:blur(8px); z-index:10;
        border:1px solid #333; display:none; min-width:340px;
    `;
    panel.innerHTML = `
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px">
            <span style="color:#8cacff;font-weight:600;font-size:12px">☀ Sun</span>
            <span id="sunElLabel" style="color:#888;font-size:10px">-</span>
        </div>
        <div style="display:flex;gap:6px;align-items:center;margin-bottom:6px">
            <input id="sunSlider" type="range" min="0" max="1439" step="1" value="720"
                style="flex:1;accent-color:#ffaa44">
            <span id="sunTimeLabel" style="min-width:36px;text-align:center;color:#eee;font-family:monospace">12:00</span>
        </div>
        <div style="display:flex;gap:6px;align-items:center;margin-bottom:6px">
            <label style="color:#888">Date</label>
            <input id="sunDate" type="date" value="${sunDateStr}"
                style="background:#222;color:#eee;border:1px solid #444;border-radius:3px;padding:2px 4px;font-size:11px">
            <button id="sunPlayBtn" style="background:#333;color:#aaa;border:1px solid #555;border-radius:3px;padding:2px 8px;cursor:pointer;font-size:11px">▶</button>
            <select id="sunSpeed" style="background:#222;color:#eee;border:1px solid #444;border-radius:3px;padding:2px;font-size:10px">
                <option value="1">1x</option>
                <option value="10">10x</option>
                <option value="60" selected>60x</option>
                <option value="360">360x</option>
                <option value="1440">1440x</option>
            </select>
        </div>
        <div style="display:flex;gap:6px;align-items:center;flex-wrap:wrap">
            <span style="color:#666;font-size:10px">📍 Front-left corner:</span>
            <label style="color:#888">Lat</label>
            <input id="sunLat" type="number" step="0.000001" value="${sunLat}"
                style="width:80px;background:#222;color:#eee;border:1px solid #444;border-radius:3px;padding:2px 4px;font-size:11px">
            <label style="color:#888">Lon</label>
            <input id="sunLon" type="number" step="0.000001" value="${sunLon}"
                style="width:80px;background:#222;color:#eee;border:1px solid #444;border-radius:3px;padding:2px 4px;font-size:11px">
            <label style="color:#888">N°</label>
            <input id="sunNorth" type="number" step="1" value="${sunNorthDeg}"
                style="width:40px;background:#222;color:#eee;border:1px solid #444;border-radius:3px;padding:2px 4px;font-size:11px"
                title="Plot north orientation: degrees from Y+ axis clockwise">
            <label style="color:#888">UTC</label>
            <input id="sunTz" type="number" step="1" value="${sunTzOffset !== null ? sunTzOffset : Math.round(sunLon / 15)}"
                style="width:40px;background:#222;color:#eee;border:1px solid #444;border-radius:3px;padding:2px 4px;font-size:11px"
                title="Timezone offset from UTC (e.g. -3 for Uruguay)">
        </div>
    `;
    document.body.appendChild(panel);

    // Events
    document.getElementById('sunSlider').addEventListener('input', (e) => {
        sunTimeMinutes = +e.target.value;
        applySunPosition();
    });
    document.getElementById('sunDate').addEventListener('change', (e) => {
        sunDateStr = e.target.value;
        applySunPosition();
    });
    document.getElementById('sunLat').addEventListener('change', (e) => {
        sunLat = +e.target.value;
        applySunPosition();
        localStorage.setItem('sunLat', sunLat);
    });
    document.getElementById('sunLon').addEventListener('change', (e) => {
        sunLon = +e.target.value;
        applySunPosition();
        localStorage.setItem('sunLon', sunLon);
    });
    document.getElementById('sunNorth').addEventListener('change', (e) => {
        sunNorthDeg = +e.target.value;
        applySunPosition();
        localStorage.setItem('sunNorth', sunNorthDeg);
    });
    document.getElementById('sunTz').addEventListener('change', (e) => {
        sunTzOffset = +e.target.value;
        applySunPosition();
        localStorage.setItem('sunTz', sunTzOffset);
    });
    document.getElementById('sunSpeed').addEventListener('change', (e) => {
        sunAnimSpeed = +e.target.value;
    });
    document.getElementById('sunPlayBtn').addEventListener('click', () => {
        sunAnimating = !sunAnimating;
        document.getElementById('sunPlayBtn').textContent = sunAnimating ? '⏸' : '▶';
        document.getElementById('sunPlayBtn').style.color = sunAnimating ? '#ffaa44' : '#aaa';
    });

    // Restore from localStorage
    const savedLat = localStorage.getItem('sunLat');
    const savedLon = localStorage.getItem('sunLon');
    const savedNorth = localStorage.getItem('sunNorth');
    if (savedLat) { sunLat = +savedLat; document.getElementById('sunLat').value = sunLat; }
    if (savedLon) { sunLon = +savedLon; document.getElementById('sunLon').value = sunLon; }
    if (savedNorth) { sunNorthDeg = +savedNorth; document.getElementById('sunNorth').value = sunNorthDeg; }
    const savedTz = localStorage.getItem('sunTz');
    if (savedTz !== null) { sunTzOffset = +savedTz; document.getElementById('sunTz').value = sunTzOffset; }
}

window.toggleSun = function() {
    const panel = document.getElementById('sunPanel');
    const btn = document.getElementById('btnSun');
    const visible = panel.style.display !== 'none';
    panel.style.display = visible ? 'none' : 'block';
    btn.classList.toggle('active', !visible);
    if (!visible) applySunPosition();
};

// State
let modelGroup = null;
let wireframeMode = false;
let objectNames = {};

// Raycaster for picking
const raycaster = new THREE.Raycaster();
const mouse = new THREE.Vector2();
let selectedMesh = null;
let highlightMaterial = null;

// Load model
const loader = new GLTFLoader();

function log(msg) {
    const el = document.getElementById('log');
    el.style.display = 'block';
    const line = document.createElement('div');
    line.textContent = `[${new Date().toLocaleTimeString()}] ${msg}`;
    el.appendChild(line);
    el.scrollTop = el.scrollHeight;
    // Keep last 20 lines
    while (el.children.length > 20) el.removeChild(el.firstChild);
    console.log(msg);
}

async function loadModel(url) {
    if (!url) url = '/dist/model.glb';

    log('Fetching model...');

    try {
        const response = await fetch(url, { cache: 'no-store' });
        if (!response.ok) {
            log(`HTTP ${response.status}: ${response.statusText}`);
            setStatus('No build yet — run: cadforge build', 'error');
            return;
        }

        const arrayBuffer = await response.arrayBuffer();
        log(`Downloaded ${(arrayBuffer.byteLength / 1024).toFixed(0)} KB`);
        setStatus('Parsing model...', 'building');

        loader.parse(arrayBuffer, '', (gltf) => {
            if (modelGroup) {
                scene.remove(modelGroup);
                modelGroup.traverse(c => {
                    if (c.isMesh) { c.geometry.dispose(); c.material.dispose(); }
                });
            }
            modelGroup = gltf.scene;
            scene.add(modelGroup);

            // Collect object names and build layers by module group
            objectNames = {};
            const layers = {};
            modelGroup.traverse((child) => {
                if (child.isMesh) {
                    // GLTFLoader: mesh is child of a named node
                    // Walk up to find node with "group::name" pattern
                    let fullName = '';
                    let node = child;
                    while (node && node !== modelGroup) {
                        if (node.name) {
                            fullName = node.name;
                            if (fullName.includes('--')) break;
                        }
                        node = node.parent;
                    }
                    if (!fullName) fullName = 'unnamed';

                    const sep = fullName.indexOf('--');
                    const group = sep > -1 ? fullName.substring(0, sep) : 'other';
                    const objName = (sep > -1 ? fullName.substring(sep + 2) : fullName).replace('.stl', '');
                    objectNames[child.uuid] = objName;
                    child.castShadow = true;
                    child.receiveShadow = true;

                    if (!layers[group]) layers[group] = [];
                    layers[group].push(child);
                }
            });
            // Debug: print first mesh's hierarchy
            let debugDone = false;
            modelGroup.traverse((c) => {
                if (c.isMesh && !debugDone) {
                    debugDone = true;
                    let path = [];
                    let n = c;
                    while (n) { path.push(n.name || '(no name)'); n = n.parent; }
                    console.log('First mesh hierarchy:', path);
                }
            });
            console.log('Layers:', Object.keys(layers), 'Total meshes:', Object.keys(objectNames).length);

            updateLayerPanel(layers);

            // Center shadow target on model
            const modelBox = new THREE.Box3().setFromObject(modelGroup);
            const modelCenter = modelBox.getCenter(new THREE.Vector3());
            dirTarget.position.copy(modelCenter);
            dirTarget.position.z = 0; // shadow target at ground level
            applySunPosition();

            fitCamera();

            const count = Object.keys(objectNames).length;
            document.getElementById('objCount').textContent = count;
            log(`Loaded ${count} objects`);
            setStatus(`Loaded: ${count} objects`, 'ok');
        }, (err) => {
            log(`Parse error: ${err.message || err}`);
            setStatus('Parse error', 'error');
        });

    } catch (err) {
        log(`Fetch error: ${err.message}`);
        setStatus('Load error', 'error');
    }
}

window.reloadModel = function() {
    log('Manual reload...');
    loadModel();
};

function fitCamera() {
    if (!modelGroup) return;
    const box = new THREE.Box3().setFromObject(modelGroup);
    const center = box.getCenter(new THREE.Vector3());
    const size = box.getSize(new THREE.Vector3());
    const maxDim = Math.max(size.x, size.y, size.z);

    controls.target.copy(center);
    // Z-up: смотрим с юго-запада сверху
    camera.position.set(
        center.x - maxDim * 0.6,
        center.y - maxDim * 0.8,
        center.z + maxDim * 0.5
    );
    camera.up.set(0, 0, 1);
    controls.update();
}

// Человекочитаемые названия групп
const GROUP_LABELS = {
    'site.ground':          'Site',
    'site.landscape':       'Landscape',
    'houses.main_house':    'Main House',
    'houses.guest_house':   'Guest House',
    'interior.walls':       'Interior Walls',
    'interior.furniture':   'Furniture',
    'exterior.roofs':       'Roofs',
    'exterior.windows':     'Windows',
    'exterior.finishing':   'Finishing',
};

function updateLayerPanel(layers) {
    const container = document.getElementById('layerList');
    container.innerHTML = '';

    // Кнопки "Все вкл / все выкл"
    const controls = document.createElement('div');
    controls.style.cssText = 'margin-bottom:6px;display:flex;gap:4px';
    const btnAll = document.createElement('button');
    btnAll.textContent = 'All';
    btnAll.style.cssText = 'font-size:10px;padding:2px 6px;background:#333;color:#aaa;border:1px solid #555;border-radius:3px;cursor:pointer';
    const btnNone = document.createElement('button');
    btnNone.textContent = 'None';
    btnNone.style.cssText = btnAll.style.cssText;
    controls.appendChild(btnAll);
    controls.appendChild(btnNone);
    container.appendChild(controls);

    const allCheckboxes = [];

    for (const [name, meshes] of Object.entries(layers).sort()) {
        const label = document.createElement('label');
        const cb = document.createElement('input');
        cb.type = 'checkbox';
        cb.checked = true;
        cb.addEventListener('change', () => {
            meshes.forEach(m => { m.visible = cb.checked; });
        });
        allCheckboxes.push({ cb, meshes });
        label.appendChild(cb);
        const displayName = GROUP_LABELS[name] || name;
        label.appendChild(document.createTextNode(` ${displayName} (${meshes.length})`));
        container.appendChild(label);
    }

    btnAll.onclick = () => {
        allCheckboxes.forEach(({ cb, meshes }) => { cb.checked = true; meshes.forEach(m => m.visible = true); });
    };
    btnNone.onclick = () => {
        allCheckboxes.forEach(({ cb, meshes }) => { cb.checked = false; meshes.forEach(m => m.visible = false); });
    };
}

// View presets (Z-up coordinate system)
window.setView = function(view) {
    if (!modelGroup) return;
    const box = new THREE.Box3().setFromObject(modelGroup);
    const center = box.getCenter(new THREE.Vector3());
    const size = box.getSize(new THREE.Vector3());
    const d = Math.max(size.x, size.y, size.z) * 1.2;

    const positions = {
        top:   [center.x, center.y, center.z + d],           // сверху, Z-up
        front: [center.x, center.y - d, center.z + d * 0.1], // спереди (юг)
        right: [center.x + d, center.y, center.z + d * 0.1], // справа (восток)
        iso:   [center.x - d * 0.6, center.y - d * 0.8, center.z + d * 0.5],
    };

    const pos = positions[view] || positions.iso;
    camera.position.set(...pos);
    camera.up.set(0, 0, 1);
    controls.target.copy(center);
    controls.update();
};

window.resetView = function() {
    fitCamera();
};

window.toggleWireframe = function() {
    wireframeMode = !wireframeMode;
    document.getElementById('btnWire').classList.toggle('active', wireframeMode);
    if (modelGroup) {
        modelGroup.traverse((child) => {
            if (child.isMesh && child.material) {
                child.material.wireframe = wireframeMode;
            }
        });
    }
};

window.toggleGrid = function() {
    gridHelper.visible = !gridHelper.visible;
    document.getElementById('btnGrid').classList.toggle('active', !gridHelper.visible);
};

// Object picking
canvas.addEventListener('click', (event) => {
    mouse.x = (event.clientX / window.innerWidth) * 2 - 1;
    mouse.y = -(event.clientY / window.innerHeight) * 2 + 1;

    raycaster.setFromCamera(mouse, camera);
    if (!modelGroup) return;

    const meshes = [];
    modelGroup.traverse(c => { if (c.isMesh) meshes.push(c); });
    const intersects = raycaster.intersectObjects(meshes);

    // Reset previous selection
    if (selectedMesh && selectedMesh._origMaterial) {
        selectedMesh.material = selectedMesh._origMaterial;
    }

    if (intersects.length > 0) {
        const mesh = intersects[0].object;
        selectedMesh = mesh;
        const name = objectNames[mesh.uuid] || 'unknown';
        document.getElementById('selName').textContent = name;

        // Highlight
        mesh._origMaterial = mesh.material;
        mesh.material = mesh.material.clone();
        mesh.material.emissive = new THREE.Color(0x3366ff);
        mesh.material.emissiveIntensity = 0.4;
    } else {
        selectedMesh = null;
        document.getElementById('selName').textContent = '-';
    }
});

// Status
function setStatus(text, state) {
    document.getElementById('statusText').textContent = text;
    const dot = document.getElementById('statusDot');
    dot.className = 'dot ' + (state || 'ok');
}

function showToast(msg, duration) {
    const toast = document.getElementById('toast');
    toast.textContent = msg;
    toast.style.display = 'block';
    setTimeout(() => { toast.style.display = 'none'; }, duration || 2000);
}

// WebSocket for hot reload
function connectWS() {
    const wsPort = 3132;
    let ws;

    function connect() {
        ws = new WebSocket(`ws://localhost:${wsPort}`);

        ws.onopen = () => {
            console.log('WS connected');
        };

        ws.onmessage = (event) => {
            const data = JSON.parse(event.data);

            switch (data.type) {
                case 'build_start':
                    setStatus('Building...', 'building');
                    showToast('Rebuilding...');
                    break;
                case 'build_complete':
                    setStatus(`Built in ${data.time}s — ${data.objects} objects`, 'ok');
                    document.getElementById('buildTime').textContent = `${data.time}s`;
                    document.getElementById('objCount').textContent = data.objects;
                    loadModel();
                    showToast('Build complete!', 1500);
                    break;
                case 'build_error':
                    setStatus('Build failed', 'error');
                    showToast('Build error!', 3000);
                    break;
            }
        };

        ws.onclose = () => {
            setTimeout(connect, 3000);
        };

        ws.onerror = () => {
            ws.close();
        };
    }

    connect();
}

// Resize
window.addEventListener('resize', () => {
    camera.aspect = window.innerWidth / window.innerHeight;
    camera.updateProjectionMatrix();
    renderer.setSize(window.innerWidth, window.innerHeight);
});

// Animate
const clock = new THREE.Clock();
function animate() {
    requestAnimationFrame(animate);
    const delta = clock.getDelta();
    if (flyMode) {
        updateFly(delta * 1000); // delta in ms for flySpeed
    } else {
        controls.update();
    }
    updateSunAnim(delta);
    renderer.render(scene, camera);
}
animate();

// Init
createSunPanel();
applySunPosition();
loadModel();
connectWS();
</script>
</body>
</html>
